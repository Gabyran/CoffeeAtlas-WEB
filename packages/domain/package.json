{
  "name": "@coffee-atlas/domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm --dir ../.. exec eslint packages/domain/src --ext .js,.jsx,.ts,.tsx",
    "test": "pnpm build && node --test --experimental-strip-types src/**/*.test.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "5.8.2"
  }
}
