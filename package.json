{
  "name": "coffeeatlas-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm dev:miniprogram:auto",
    "dev:api": "pnpm --filter @coffeeatlas/api dev",
    "dev:miniprogram:auto": "node scripts/miniprogram-auto-repush.mjs",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.21.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "9.21.0",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.0.0"
  }
}
