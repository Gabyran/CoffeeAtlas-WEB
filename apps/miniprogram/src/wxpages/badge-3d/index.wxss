.test-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f1e8 0%, #fdfaf4 42%, #fffdf8 100%);
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

.test-page__header {
  margin-bottom: 40rpx;
}

.test-page__title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #3e2a1e;
}

.test-page__subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: rgba(107, 83, 68, 0.72);
}

.test-page__body {
  padding: 40rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(107, 83, 68, 0.08);
  margin-bottom: 40rpx;
}

.test-page__status {
  display: block;
  font-size: 32rpx;
  color: #4a8c5c;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.test-page__url {
  display: block;
  font-size: 24rpx;
  color: rgba(107, 83, 68, 0.6);
  word-break: break-all;
}

.test-page__footer {
  margin-top: 40rpx;
}

.test-page__back {
  display: inline-flex;
  align-items: center;
  padding: 20rpx 40rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4e342e 0%, #3e2a1e 100%);
  box-shadow: 0 18rpx 32rpx rgba(62, 42, 30, 0.18);
}

.test-page__back-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}
