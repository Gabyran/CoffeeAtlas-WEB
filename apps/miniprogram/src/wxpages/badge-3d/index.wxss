.badge-3d-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, #f7f1e8 0%, #fdfaf4 42%, #fffdf8 100%);
  overflow: hidden;
}

.badge-3d-nav {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 8px 16px;
  height: 44px;
}

.badge-3d-back {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px;
  min-width: 60px;
}

.badge-3d-back-arrow {
  font-size: 20px;
  color: #3e2a1e;
}

.badge-3d-back-text {
  font-size: 15px;
  color: #3e2a1e;
  font-weight: 500;
}

.badge-3d-title {
  flex: 1;
  text-align: center;
  font-size: 17px;
  font-weight: 600;
  color: #3e2a1e;
}

.badge-3d-nav-spacer {
  width: 60px;
}

.badge-3d-scene {
  width: 100%;
  height: 100%;
}

.badge-3d-loading {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 5;
  background: rgba(247, 241, 232, 0.92);
}

.badge-3d-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid rgba(139, 90, 43, 0.2);
  border-top-color: #c85c3d;
  border-radius: 50%;
  animation: badge3d-spin 0.8s linear infinite;
}

@keyframes badge3d-spin {
  to { transform: rotate(360deg); }
}

.badge-3d-loading-text {
  margin-top: 12px;
  font-size: 13px;
  color: rgba(107, 83, 68, 0.72);
}

.badge-3d-error {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 5;
  padding: 32px;
  box-sizing: border-box;
}

.badge-3d-error-text {
  font-size: 14px;
  color: rgba(107, 83, 68, 0.72);
  text-align: center;
  margin-bottom: 16px;
  line-height: 1.6;
}

.badge-3d-retry-btn {
  padding: 10px 32px;
  border-radius: 999px;
  background: linear-gradient(135deg, #4e342e 0%, #3e2a1e 100%);
  box-shadow: 0 9px 16px rgba(62, 42, 30, 0.18);
}

.badge-3d-retry-text {
  font-size: 14px;
  font-weight: 600;
  color: #fff;
}

.badge-3d-hint {
  position: absolute;
  bottom: 80px;
  left: 0;
  right: 0;
  text-align: center;
  animation: badge3d-fadeout 3s ease forwards;
  z-index: 6;
}

.badge-3d-hint-text {
  font-size: 12px;
  color: rgba(107, 83, 68, 0.5);
  background: rgba(255, 255, 255, 0.8);
  padding: 6px 16px;
  border-radius: 999px;
}

@keyframes badge3d-fadeout {
  0%, 60% { opacity: 1; }
  100% { opacity: 0; }
}
