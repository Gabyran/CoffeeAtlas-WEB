<xr-scene>
  <xr-assets>
    <xr-asset-load type="gltf" asset-id="badgeModel" src="{{modelUrl}}" />
  </xr-assets>

  <xr-light type="ambient" color="1 1 1" intensity="0.6" />
  <xr-light type="directional" rotation="40 70 0" color="1 1 1" intensity="2" />
  <xr-light type="directional" rotation="-20 -30 0" color="0.9 0.85 0.8" intensity="0.8" />

  <xr-gltf model="badgeModel" position="0 0 0" scale="1 1 1" />

  <xr-camera
    clear-color="0.97 0.95 0.92 1"
    position="0 0.5 3"
    target="0 0 0"
    camera-orbit-control
    fov="45"
  />
</xr-scene>
