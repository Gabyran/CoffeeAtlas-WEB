    "cleanup:taobao:offshelf": "node --experimental-strip-types scripts/cleanup-taobao-offshelf.ts",
    "sync:taobao:daily": "node --experimental-strip-types scripts/daily-taobao-sync.ts",
    "import:roasters": "node --experimental-strip-types scripts/import-roasters.ts",
    "import:beans": "node --experimental-strip-types scripts/import-beans.ts",
    "import:sales": "node --experimental-strip-types scripts/import-sales.ts",
