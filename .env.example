# =============================================================================
# CoffeeStories WebDB - Environment Variables Configuration
# =============================================================================
# This file contains all environment variables required for the application.
# DO NOT commit actual values to version control - use .env.example as template.
# =============================================================================

# =============================================================================
# Supabase Configuration
# =============================================================================
# Supabase Project URL
# Format: https://<project-ref>.supabase.co
# Get from: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Anonymous Key (client-side)
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Get from: Supabase Dashboard → Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (server-side, admin operations)
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# WARNING: This key has full database access - never expose to client-side
# Get from: Supabase Dashboard → Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Application Configuration
# =============================================================================
# Node environment
# Values: development, test, production
NODE_ENV=development

# Application port
# Default: 3000
APP_PORT=3000

# Admin API bearer token for /admin pages and /api/admin/* write endpoints.
# Generate a long random string, for example with:
# openssl rand -base64 32
ADMIN_API_TOKEN=

# =============================================================================
# Optional: Third-party Service Configuration
# =============================================================================
# JWT secret used by /api/v1/auth/wechat/login
# Generate a long random string, for example with:
# openssl rand -base64 32
APP_JWT_SECRET=

# WeChat miniprogram credentials used by jscode2session
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Optional miniprogram API domain.
# Development can point to a LAN IP; cloud debugging should use an HTTPS domain.
TARO_APP_API_URL=

# Miniprogram Supabase read-only access.
# Defaults to NEXT_PUBLIC_SUPABASE_* when omitted, but keeping them explicit helps avoid stale builds.
TARO_APP_SUPABASE_URL=https://lkadpxktijdtibftuuwi.supabase.co
TARO_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxrYWRweGt0aWpkdGliZnR1dXdpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEwNjE1MTYsImV4cCI6MjA4NjYzNzUxNn0.IhprBtwAyv5A1ZaG7mYYLTWvu2fAZcS01DQjBrEMEWU

# =============================================================================
# Taobao sync (internal)
# =============================================================================
TAOBAO_MCP_URL=http://localhost:3655/mcp
TAOBAO_SYNC_MAX_ITEMS_PER_SHOP=20
TAOBAO_SYNC_DELAY_MIN_MS=1400
TAOBAO_SYNC_DELAY_MAX_MS=2600

# Optional OCR/vision fallback
VISION_BASE_URL=
VISION_API_KEY=
VISION_MODEL=
